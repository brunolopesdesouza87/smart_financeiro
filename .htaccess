# Serve SPA from dist/ folder
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve real files from dist/ (assets, index.html, vite.svg)
  RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f
  RewriteRule ^(.*)$ dist/$1 [L]

  # Fallback: all routes -> dist/index.html (React Router SPA)
  RewriteRule ^ dist/index.html [L]
</IfModule>
