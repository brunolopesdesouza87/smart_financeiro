# Serve SPA from dist/ folder
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve real files (including dist/assets/) directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # All other routes -> dist/index.html (React Router SPA)
  RewriteRule ^ dist/index.html [L]
</IfModule>
